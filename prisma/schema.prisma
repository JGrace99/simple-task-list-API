// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`
generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}
// Data Model: field name, field type, arguments
// Everytie a data model is changed a migration must be run for those changes to be applied to the database. Note: Similar to EF Core
model Task {
  // Primary Key or identifier of a Task
  id Int @id @default(autoincrement())

  // Name of task is required
  title String 

  // Upon creation of task it hasn't been completed -> default to false
  completed Boolean @default(false)

  // Use the current time stamp upon creation and assign it to createdAt
  createdAt DateTime @default(now())

  // Optional intially since no update occured
  // Note: Could make this createdAt
  updatedAt DateTime?
}
